{
  "version": 2,
  "builds": [
    {
      "src": "BACKEND/src/server.js", 
      "use": "@vercel/node"
    },
    {
      "src": "FRONTEND/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "BACKEND/src/server.js" },
    { "source": "/(.*)", "destination": "FRONTEND/$1" }
  ]
}